{
  "allowedExtensions": [".pdf", ".xlsx", ".csv", ".zip"],
  "blockedExtensions": [".exe", ".bat"],
  "senderAllowList": ["@example.co.jp"],
  "senderBlockList": ["spam@"],

  "saveMode": "body+attachments",
  "maxFileSizeMB": 50,
  "sinceMinutes": 1440,
  "backupBase": "C:/mail-backups",

  "domainFolderMap": {
    "example.com": "Example",
    "another-domain.com": "AnotherDomain"
  },

  "folderRules": [
    {
      "name": "INBOX__MOVE__example",
      "mailbox": "INBOX",
      "targetImapFolder": "INBOX.00_example",
      "targetLocalSubpath": "01_IN/00_example",
      "conditions": {
        "recipientEquals": "user@example.com"
      }
    },
    {
      "name": "INBOX.Sent__MOVE__example",
      "mailbox": "INBOX.Sent",
      "targetImapFolder": "INBOX.00_example",
      "targetLocalSubpath": "02_OUT",
      "domainFolderMap": {
      },
      "conditions": {
        "recipientEquals": "user@example.com"
      }
    }
  ]
}
