{
  "name": "imap-mail-backup",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node ./dist/main.js",
    "start:ts": "ts-node ./src/main.ts",
    "check-mailboxes:js": "npm run build && node ./dist/checkMailboxes.js",
    "check-mailboxes:ts": "ts-node ./src/checkMailboxes.ts",
    "task:create": "powershell -ExecutionPolicy Bypass -File ./scripts/create-task.ps1",
    "task:delete": "powershell -ExecutionPolicy Bypass -File ./scripts/delete-task.ps1",
    "task:info": "powershell -Command \"Get-ScheduledTask -TaskName 'ImapMailBackupTask' | Get-ScheduledTaskInfo | Format-List\"",
    "open:backups": "powershell -Command \"Start-Process explorer.exe '.\\mail-backups'\""
  },
  "dependencies": {
    "imapflow": "latest",
    "mailparser": "latest",
    "node-imap": "^0.9.6"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^18.16.0",
    "@types/node-imap": "^0.9.3",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
