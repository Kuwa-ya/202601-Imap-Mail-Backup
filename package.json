{
  "name": "imap-mail-backup",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && node ./dist/cli/processRules.js",
    "check-mailboxes:ts": "ts-node ./src/cli/checkMailboxes.ts",
    "process-rules:ts": "ts-node ./src/cli/processRules.ts",
    "check-mailboxes:js": "node ./dist/cli/checkMailboxes.js",
    "process-rules:js": "node ./dist/cli/processRules.js",
    "task:create": "powershell -ExecutionPolicy Bypass -File ./scripts/create-task.ps1",
    "task:delete": "powershell -ExecutionPolicy Bypass -File ./scripts/delete-task.ps1"
  },
  "dependencies": {
    "imapflow": "latest",
    "mailparser": "latest",
    "node-imap": "^0.9.6"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^18.16.0",
    "@types/node-imap": "^0.9.3",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
