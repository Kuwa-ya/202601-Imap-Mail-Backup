{
  "name": "imap-mail-backup",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",

    "start": "node ./dist/main.js",
    "check-mailboxes": "node ./dist/checkMailboxes.js",
    "open-backups": "node ./dist/openBackups.js",

    "start:dev": "ts-node ./src/main.ts",
    "check-mailboxes:dev": "ts-node ./src/checkMailboxes.ts",
    "open-backups:dev": "ts-node ./src/openBackups.ts",

    "start:build": "npm run build && npm run start",
    "check-mailboxes:build": "npm run build && npm run check-mailboxes",
    "open-backups:build": "npm run build && npm run open-backups",

    "task:create": "powershell -ExecutionPolicy Bypass -File ./scripts/create-task.ps1",
    "task:delete": "powershell -ExecutionPolicy Bypass -File ./scripts/delete-task.ps1",
    "task:info": "powershell -Command \"Get-ScheduledTask -TaskName 'ImapMailBackupTask' | Get-ScheduledTaskInfo | Format-List\""
  },
  "dependencies": {
    "imapflow": "latest",
    "mailparser": "latest",
    "node-imap": "^0.9.6"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^18.16.0",
    "@types/node-imap": "^0.9.3",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
